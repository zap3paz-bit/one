# Copy this file to .env for local testing only.
# On your hosting platform (Render/Railway/Fly.io/etc.), set these as
# dashboard/CLI environment variables instead — don't upload a real .env file.

TWILIO_ACCOUNT_SID=your_twilio_account_sid
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_FROM_NUMBER=+1234567890

# Optional: lock down which origin may call /api/send-sms.
# Leave unset (or "*") while testing; set to your real gc.html URL once deployed.
ALLOWED_ORIGIN=*
