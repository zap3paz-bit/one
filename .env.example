# Copy this file to .env for local testing only.
# On your hosting platform (Render/Railway/Fly.io/etc.), set these as
# dashboard/CLI environment variables instead — don't upload a real .env file.

# Required for the "upload a question paper, AI interprets it" feature.
# Free tier, no credit card needed. Get a key from https://aistudio.google.com/apikey
GEMINI_API_KEY=your_gemini_api_key

# Optional: override the Gemini model (defaults to gemini-2.5-flash if unset).
# GEMINI_MODEL=gemini-2.5-flash
